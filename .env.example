# Provider LLM padrão: anthropic | openai
LLM_PROVIDER=anthropic

# Modelo padrão. Exemplos:
# Anthropic: claude-sonnet-4-6
# OpenAI/Codex: gpt-4.1-mini
LLM_MODEL=

# Anthropic API key — obtenha em https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — obtenha em https://platform.openai.com
# OPENAI_API_KEY=sk-...

# Opcional: base URL alternativa para providers compatíveis com OpenAI
# LLM_BASE_URL=https://api.openai.com/v1

# Diretório de persistência do ChromaDB (relativo à raiz do projeto)
CHROMA_PERSIST_DIR=./modules/vector_store/chroma_db

# Modelo sentence-transformers para embeddings locais (CPU)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Opcional: Tavily Search API para busca web mais rica nos agentes
# TAVILY_API_KEY=tvly-...
