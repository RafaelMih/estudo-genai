# Anthropic Claude API key — obtenha em https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Diretório de persistência do ChromaDB (relativo à raiz do projeto)
CHROMA_PERSIST_DIR=./modules/vector_store/chroma_db

# Modelo sentence-transformers para embeddings locais (CPU)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Opcional: Tavily Search API para busca web mais rica nos agentes
# TAVILY_API_KEY=tvly-...
